    <!-- Shizuku Help -->
    <string name="shizuku_help_step1_title">下載 Shizuku</string>
    <string name="shizuku_help_step1_desc">從 Google Play 或 GitHub 下載 Shizuku 應用\n\n• Google Play: 搜索 \"Shizuku\"\n• GitHub: github.com/RikkaApps/Shizuku</string>
    <string name="shizuku_help_step2_title">啟動 Shizuku</string>
    <string name="shizuku_help_step2_desc">打開 Shizuku 應用，根據您的設備選擇啟動方式：\n\n• 無線調試（推薦）：需要 Android 11+，在開發者選項中開啟無線調試\n• 連接電腦：通過 ADB 命令啟動</string>
    <string name="shizuku_help_step3_title">授權Alian</string>
    <string name="shizuku_help_step3_desc">在 Shizuku 的「應用管理」中找到Alian Autopilot，點擊授權按鈕</string>
    <string name="shizuku_help_step4_title">開始使用</string>
    <string name="shizuku_help_step4_desc">授權完成後，返回Alian應用，狀態卡片會顯示「Shizuku 已連接」</string>

    <!-- Overlay Help -->
    <string name="overlay_why">為什麼需要懸浮窗權限？</string>
    <string name="overlay_reason">Alian在執行任務時需要顯示懸浮窗來：</string>
    <string name="overlay_feature1">顯示當前執行進度</string>
    <string name="overlay_feature2">提供停止按鈕，隨時中斷任務</string>
    <string name="overlay_feature3">在其他應用上方顯示狀態信息</string>
    <string name="overlay_how">如何開啟？</string>
    <string name="overlay_how_desc">1. 點擊執行任務時會自動提示\n2. 或前往：設定 > 應用 > Alian > 懸浮窗權限\n3. 開啟「允許顯示在其他應用上層」</string>
    <string name="overlay_privacy">隱私安全</string>
    <string name="overlay_privacy_desc">懸浮窗僅在任務執行期間顯示，不會收集任何個人信息。任務完成後懸浮窗會自動消失。</string>

