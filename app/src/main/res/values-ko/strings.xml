    <string name="onboarding_ai">AI 구동</string>
    <string name="onboarding_ai_desc">첨단 시각 언어 모델을 기반으로,\nAlian은 화면 내용을 이해하고 지능적인 결정을 내립니다</string>
    <string name="onboarding_easy">사용하기 쉬움</string>
